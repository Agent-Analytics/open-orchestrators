---
import type { OrchestrationToolEntry } from "../data/orchestrators";

interface Props {
  tool: OrchestrationToolEntry;
  delay?: number;
  trackingSource?: string;
  trackingEvent?: string;
}

const {
  tool,
  delay = 0,
  trackingSource = "tools_section",
  trackingEvent = "orchestration_tool_click"
} = Astro.props;
const trackingPayload = JSON.stringify({
  tool_slug: tool.slug,
  source: trackingSource
});
---

<article
  class="tool-card reveal"
  style={`--delay:${delay}ms;`}
  aria-labelledby={`tool-${tool.slug}`}
>
  <div class="tool-card__top">
    <div class:list={["tool-card__mark", tool.logoSrc && "tool-card__mark--image"]} aria-hidden="true">
      {tool.logoSrc ? (
        <img
          src={tool.logoSrc}
          alt={tool.logoAlt ?? `${tool.title} logo`}
          class="tool-card__logo"
          loading="lazy"
          decoding="async"
        />
      ) : (
        tool.mark
      )}
    </div>
    <div>
      <p class="tool-card__source">{tool.sourceName}</p>
      <h3 class="tool-card__title" id={`tool-${tool.slug}`}>
        <a
          href={tool.url}
          target="_blank"
          rel="noreferrer"
          onclick={`window.aa?.track('${trackingEvent}', ${trackingPayload})`}
        >
          {tool.title}
        </a>
      </h3>
    </div>
  </div>

  <p class="tool-card__summary">{tool.summary}</p>
  <p class="tool-card__note">{tool.note}</p>

  <ul class="tag-list" aria-label={`${tool.title} tags`}>
    {tool.tags.map((tag) => <li>{tag}</li>)}
  </ul>

  <a
    href={tool.url}
    target="_blank"
    rel="noreferrer"
    class="text-link"
    onclick={`window.aa?.track('${trackingEvent}', ${trackingPayload})`}
  >
    {tool.ctaLabel ?? "Open tool"}
  </a>
</article>
