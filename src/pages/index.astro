---
import ContributionSection from "../components/ContributionSection.astro";
import DirectoryCard from "../components/DirectoryCard.astro";
import NewsCard from "../components/NewsCard.astro";
import NewsTicker from "../components/NewsTicker.astro";
import ToolCard from "../components/ToolCard.astro";
import {
  implementationServices,
  orchestrators,
  orchestrationTools,
  siteMeta
} from "../data/orchestrators";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getPublishedNewsPosts } from "../lib/news";

const byRank = (
  a: (typeof orchestrators)[number],
  b: (typeof orchestrators)[number]
) => a.rank - b.rank;
const openOrchestrators = orchestrators
  .filter((entry) => entry.visibility !== "not-open-important")
  .slice()
  .sort(byRank);
const importantNotOpenOrchestrators = orchestrators
  .filter((entry) => entry.visibility === "not-open-important")
  .slice()
  .sort(byRank);
const rankedOrchestrators = orchestrators.slice().sort(byRank);
const totalEntries = orchestrators.length;
const newsPosts = await getPublishedNewsPosts();
const featuredNews = newsPosts[0];
const secondaryNews = newsPosts.slice(1, 4);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: siteMeta.name,
  description: siteMeta.description,
  url: siteMeta.canonicalUrl,
  mainEntity: {
    "@type": "ItemList",
    name: "Open Orchestrators directory",
    numberOfItems: totalEntries,
    itemListElement: rankedOrchestrators.map((entry) => ({
      "@type": "ListItem",
      position: entry.rank,
      name: entry.title,
      url: new URL(`/players/${entry.slug}/`, siteMeta.canonicalUrl).toString()
    }))
  }
};
---

<BaseLayout
  title={siteMeta.pageTitle}
  description={siteMeta.description}
  pathname="/"
  ogImage="/assets/open-orchestrators-og.png"
  jsonLd={jsonLd}
>
  <div class="page-shell">
    <header class="masthead reveal">
      <a href="/" class="masthead__brand">
        <span class="masthead__wordmark">Open Orchestrators</span>
        <span class="masthead__byline">Open multi-agent orchestration platforms directory and news</span>
      </a>
      <nav class="masthead__actions" aria-label="Primary">
        <a href="#news" class="masthead__link">News</a>
        <a href="#directory" class="masthead__link">Directory</a>
        {importantNotOpenOrchestrators.length > 0 && (
          <a href="#important" class="masthead__link">Important</a>
        )}
        <a href="#tools" class="masthead__link">Tools</a>
        <a href="/news/" class="masthead__link">Archive</a>
        <a
          href="https://github.com/Agent-Analytics/awesome-multi-agent-orchestrators"
          target="_blank"
          rel="noreferrer"
          class="masthead__link"
        >
          GitHub
        </a>
      </nav>
    </header>

    <NewsTicker posts={newsPosts} source="home_ticker" />

    <main>
      <section id="news" class="hero section">
        <div class="hero__grid">
          <div class="hero__copy reveal" style="--delay:100ms;">
            <p class="section-kicker">Open Orchestrators</p>
            <h1 class="display-title">Open multi-agent orchestration platforms directory and news.</h1>
            <p class="hero__lede">
              Track the projects shaping multi-agent orchestration, then compare the
              builders, workspaces, company OSes, coordination protocols, and visual
              systems in one place. Closed products that matter to the community are
              separated from the open directory.
            </p>

            <div class="hero__meta" aria-label="Directory stats">
              <span class="meta-pill">
                <strong>{String(totalEntries).padStart(2, "0")}</strong>
                <span>projects</span>
              </span>
              <span class="meta-pill">
                <strong>{String(newsPosts.length).padStart(2, "0")}</strong>
                <span>news posts</span>
              </span>
            </div>
          </div>

          <aside class="hero__aside reveal" style="--delay:180ms;">
            {featuredNews ? (
              <>
                <p class="directory-card__note-label">Latest story</p>
                <NewsCard post={featuredNews} featured />
              </>
            ) : (
              <>
                <figure class="hero__art-frame">
                  <img
                    src="/assets/open-orchestrators-hero.png"
                    alt="Editorial illustration of connected orchestration cards and nodes"
                    class="hero__art"
                    width="1200"
                    height="896"
                  />
                </figure>
                <p class="directory-card__note-label">What is in the cut</p>
                <p class="hero__aside-copy">
                  Parallel agent runners, workspaces, company OSes, coordination protocols, and visual builders.
                </p>
              </>
            )}
          </aside>
        </div>
      </section>

      {secondaryNews.length > 0 && (
        <section class="section">
          <div class="section-heading">
            <div>
              <p class="section-kicker">Latest news</p>
              <h2>News</h2>
            </div>
            <a href="/news/" class="text-link">All news</a>
          </div>
          <div class="news-grid">
            {secondaryNews.map((post, index) => (
              <NewsCard post={post} delay={260 + index * 55} />
            ))}
          </div>
        </section>
      )}

      <section id="directory" class="section">
        <div class="section-heading">
          <div>
            <p class="section-kicker">Directory</p>
            <h2>Multi-agent orchestration platforms.</h2>
            <p class="section-intro">
              Open-source or publicly documented systems where orchestration is central to the product.
            </p>
          </div>
        </div>
        <div class="directory-grid">
          {openOrchestrators.map((entry, index) => (
            <DirectoryCard entry={entry} delay={280 + index * 55} />
          ))}
        </div>
      </section>

      {importantNotOpenOrchestrators.length > 0 && (
        <section id="important" class="section">
          <div class="section-heading">
            <div>
              <p class="section-kicker">Not open, important</p>
              <h2>Closed products shaping the category.</h2>
              <p class="section-intro">
                These products are not open-source projects, but they are important enough to track because they influence how builders think about multi-agent orchestration.
              </p>
            </div>
          </div>
          <div class="directory-grid">
            {importantNotOpenOrchestrators.map((entry, index) => (
              <DirectoryCard entry={entry} delay={280 + index * 55} />
            ))}
          </div>
        </section>
      )}

      <section id="tools" class="section">
        <div class="section-heading">
          <div>
            <p class="section-kicker">Tools</p>
            <h2>Tools that make multi-agent orchestration better.</h2>
          </div>
        </div>
        <div class="tool-grid">
          {orchestrationTools.map((tool, index) => (
            <ToolCard tool={tool} delay={280 + index * 55} />
          ))}
        </div>
      </section>

      <section id="services" class="section">
        <div class="section-heading">
          <div>
            <p class="section-kicker">Services</p>
            <h2>Implementation services for production agent teams.</h2>
            <p class="section-intro">
              Services companies and consultants that publish practical material on deploying, hardening, and operating multi-agent systems. These are not player entries.
            </p>
          </div>
        </div>
        <div class="tool-grid">
          {implementationServices.map((service, index) => (
            <ToolCard
              tool={service}
              delay={280 + index * 55}
              trackingSource="services_section"
              trackingEvent="implementation_service_click"
            />
          ))}
        </div>
      </section>
    </main>

    <ContributionSection />
  </div>
</BaseLayout>
